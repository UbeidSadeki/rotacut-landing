---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Products from "../components/Products/index.astro";
import WhyRotacut from "../components/WhyRotacut.astro";
import Materials from "../components/Materials.astro";
import Industries from "../components/Industries.astro";
import StatsBar from "../components/StatsBar.astro";
import DealerCTA from "../components/DealerCTA.astro";
import Footer from "../components/Footer.astro";

const base = import.meta.env.BASE_URL;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={`${base}logo.png`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Rotacut — Precision Annular Cutters</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Nav />
    <Hero />
    <Products />
    <WhyRotacut />
    <Materials />
    <Industries />
    <StatsBar />
    <DealerCTA />
    <Footer />
  </body>
</html>
