        <p class="footer-tagline">
          Precision-Engineered Annular Cutters — Built to Perform. Trusted by professionals
          worldwide.
        </p>
      </div>
      <div>
        <p class="footer-col-title">Products</p>
        <ul class="footer-links">
          <li><a href="#products">TCT Annular Cutters</a></li>
          <li><a href="#products">TCT Rail Cutters</a></li>
          <li><a href="#products">HSS Annular Cutters</a></li>
          <li><a href="#products">Pilot Pins</a></li>
        </ul>
      </div>
      <div>
        <p class="footer-col-title">Company</p>
        <ul class="footer-links">
          <li><a href="#">About Rotacut</a></li>
          <li><a href="#">Dealer Network</a></li>
          <li><a href="#">Download Catalogue</a></li>
          <li><a href="#">Contact Us</a></li>
        </ul>
      </div>
      <div>
        <p class="footer-col-title">Resources</p>
