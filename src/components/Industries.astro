---
import Building2 from "@lucide/astro/icons/building-2";
import TrainFront from "@lucide/astro/icons/train-front";
import Anchor from "@lucide/astro/icons/anchor";
import Zap from "@lucide/astro/icons/zap";
import Fuel from "@lucide/astro/icons/fuel";
import Pickaxe from "@lucide/astro/icons/pickaxe";
import Cog from "@lucide/astro/icons/cog";
import Plane from "@lucide/astro/icons/plane";
---

<section id="industries" class="industries-section">
  <div class="divider"></div>
  <div style="height:7rem;"></div>
  <div class="container">
    <div class="section-label"><span>Industries</span></div>
    <h2 class="section-title">Trusted Across Industries</h2>
    <p class="section-sub">
      From shipbuilding floors to oil platforms, Rotacut cutters perform where it matters most.
    </p>
  </div>
  <div class="industries-grid">
    <div class="industry-item">
      <div class="industry-icon"><Building2 size={32} /></div>
      <div class="industry-name">Steel Fabrication</div>
    </div>
    <div class="industry-item">
      <div class="industry-icon"><TrainFront size={32} /></div>
      <div class="industry-name">Railway &amp; Infrastructure</div>
    </div>
    <div class="industry-item">
      <div class="industry-icon"><Anchor size={32} /></div>
      <div class="industry-name">Shipbuilding &amp; Marine</div>
    </div>
    <div class="industry-item">
      <div class="industry-icon"><Zap size={32} /></div>
      <div class="industry-name">Power &amp; Energy</div>
    </div>
    <div class="industry-item">
      <div class="industry-icon"><Fuel size={32} /></div>
      <div class="industry-name">Oil &amp; Gas / Pipeline</div>
    </div>
    <div class="industry-item">
      <div class="industry-icon"><Pickaxe size={32} /></div>
      <div class="industry-name">Mining &amp; Heavy Equipment</div>
    </div>
    <div class="industry-item">
      <div class="industry-icon"><Cog size={32} /></div>
      <div class="industry-name">General Engineering</div>
    </div>
    <div class="industry-item">
      <div class="industry-icon"><Plane size={32} /></div>
      <div class="industry-name">Automotive &amp; Aerospace</div>
    </div>
  </div>
</section>

<style>
  .industries-section {
    background: var(--bg2);
    padding-top: 0;
  }

  .industries-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
    max-width: 1200px;
    margin: 0 auto;
  }

  .industry-item {
    background: var(--bg2);
    padding: 2rem;
    text-align: center;
    transition: background 0.3s;
    cursor: default;
  }

  .industry-item:hover {
    background: #1a0808;
  }

  .industry-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .industry-name {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    font-weight: 500;
  }

  @media (max-width: 1024px) {
    .industries-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 768px) {
    .industries-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
