---
import Mail from "@lucide/astro/icons/mail";
import Globe from "@lucide/astro/icons/globe";
import { Phone } from "@lucide/astro";
import DealerForm from "./DealerForm.astro";
---

<section id="dealer" class="dealer-section">
  <div class="dealer-grid">
    <div class="dealer-half">
      <div class="dealer-label">Find a Dealer</div>
      <h3 class="dealer-title">Get Rotacut Near You</h3>
      <p class="dealer-text">
        Our authorised dealer network spans 30+ countries. Contact us to find your nearest Rotacut
        stockist or request a direct quote for your project.
      </p>
      <a href="#contact" class="btn-primary">Find a Dealer</a>
      <div class="contact-info">
        <p class="contact-info-row-company-label">Rotacut Tools Pvt Ltd.</p>
        <p class="contact-info-label">Quick Contact</p>
        <p class="contact-info-row">
          <Mail size={14} />{" "}info@rotacut.com
        </p>
        <p class="contact-info-row">
          <Globe size={14} />{" "}www.rotacut.com
        </p>
        <a
          href="tel:+917405474010"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-info-row"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line
              x1="12"
              y1="18"
              x2="12.01"
              y2="18"></line></svg
          >
          + 91 74054 74010
        </a>
        <a
          href="tel:02882551920"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-info-row"
        >
          <Phone size={14} />{" "}0288-2551920
        </a>
      </div>
    </div>
    <div class="dealer-half dealer-half--alt" id="contact">
      <div class="dealer-label">Become a Dealer</div>
      <h3 class="dealer-title">Join Our Network</h3>
      <p class="dealer-text">
        Interested in carrying Rotacut products? Fill out the form below and our team will get back
        to you within 24 hours.
      </p>
      <DealerForm />
    </div>
  </div>
</section>

<style>
  .dealer-section {
    padding: 0;
  }

  .dealer-section .btn-primary {
    display: block;
    width: fit-content;
  }

  .dealer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
  }

  .dealer-half {
    padding: 4rem;
    background: var(--bg2);
  }

  .dealer-half--alt {
    background: var(--bg3);
  }

  .dealer-label {
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--orange);
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .dealer-title {
    font-family: "Bebas Neue", sans-serif;
    font-size: 2.8rem;
    letter-spacing: 0.03em;
    color: #fff;
    margin: 0 0 1rem;
    line-height: 1;
  }

  .dealer-text {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 2rem;
    font-weight: 300;
  }

  .contact-info {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .contact-info-label {
    font-size: 0.8rem;
    color: var(--muted);
    margin-bottom: 0.5rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .contact-info-row {
    text-decoration: none;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.7);
    font-weight: 300;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.3rem;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    margin-block: 1rem;
  }
  .contact-info-row-company-label {
    font-size: 1.2rem;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .dealer-grid {
      grid-template-columns: 1fr;
    }

    .dealer-half {
      padding: 2.5rem 1.5rem;
    }
  }
</style>
