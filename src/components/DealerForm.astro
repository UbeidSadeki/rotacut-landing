<form class="dealer-form" onsubmit="return false;">
  <div class="form-row">
    <input class="form-input" type="text" placeholder="Your Name" />
    <input class="form-input" type="text" placeholder="Company Name" />
  </div>
  <div class="form-row">
    <input class="form-input" type="email" placeholder="Email Address" />
    <input class="form-input" type="tel" placeholder="Phone Number" />
  </div>

  <!-- Custom Select -->
  <div class="custom-select" id="productSelect">
    <input type="hidden" name="product_interest" id="productValue" />
    <button type="button" class="select-trigger form-input" aria-haspopup="listbox" aria-expanded="false">
      <span class="select-label">Product Interest</span>
      <svg class="select-chevron" xmlns="http://www.w3.org/2000/svg" width="12" height="8" viewBox="0 0 12 8" fill="none">
        <path d="M1 1l5 5 5-5" stroke="#888" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <ul class="select-dropdown" role="listbox" aria-label="Product Interest">
      <li class="select-option" role="option" data-value="TCT Annular Cutters">TCT Annular Cutters</li>
      <li class="select-option" role="option" data-value="TCT Rail Cutters">TCT Rail Cutters</li>
      <li class="select-option" role="option" data-value="HSS Annular Cutters">HSS Annular Cutters</li>
      <li class="select-option" role="option" data-value="Pilot Pins">Pilot Pins</li>
      <li class="select-option" role="option" data-value="Full Range">Full Range</li>
    </ul>
  </div>

  <textarea
    class="form-input"
    rows="3"
    placeholder="Message / Project Details"
    style="resize:vertical;"></textarea>
  <button type="submit" class="btn-primary btn-submit">Send Enquiry</button>
</form>

<style>
  .dealer-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-input {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border);
    color: #fff;
    padding: 0.875rem 1rem;
    font-size: 0.875rem;
    font-family: "Barlow", sans-serif;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
    box-sizing: border-box;
  }

  .form-input:focus {
    border-color: var(--red);
  }

  .form-input::placeholder {
    color: rgba(255, 255, 255, 0.25);
  }

  /* Custom Select */
  .custom-select {
    position: relative;
    width: 100%;
  }

  .select-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    text-align: left;
    appearance: none;
    -webkit-appearance: none;
  }

  .select-trigger:focus {
    border-color: var(--red);
  }

  .select-trigger[aria-expanded="true"] {
    border-color: var(--red);
  }

  .select-label {
    color: rgba(255, 255, 255, 0.25);
    transition: color 0.2s;
    font-size: 0.875rem;
    font-family: "Barlow", sans-serif;
    font-weight: 400;
  }

  .select-label.selected {
    color: #fff;
  }

  .select-chevron {
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .select-trigger[aria-expanded="true"] .select-chevron {
    transform: rotate(180deg);
  }

  .select-trigger[aria-expanded="true"] .select-chevron path {
    stroke: var(--red);
  }

  .select-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 2px);
    left: 0;
    right: 0;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-top: 1px solid var(--red);
    list-style: none;
    margin: 0;
    padding: 0.25rem 0;
    z-index: 100;
    animation: dropdownOpen 0.15s ease;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
  }

  .select-dropdown.open {
    display: block;
  }

  @keyframes dropdownOpen {
    from {
      opacity: 0;
      transform: translateY(-4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .select-option {
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    font-family: "Barlow", sans-serif;
    color: rgba(255, 255, 255, 0.7);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    border-left: 2px solid transparent;
  }

  .select-option:hover {
    background: rgba(204, 0, 0, 0.12);
    color: #fff;
    border-left-color: var(--red);
  }

  .select-option.active {
    background: rgba(204, 0, 0, 0.08);
    color: var(--red);
    border-left-color: var(--red);
  }

  .btn-submit {
    border: none;
    cursor: pointer;
    text-align: center;
    justify-content: center;
    width: 100%;
  }

  @media (max-width: 768px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  function initCustomSelect(container: HTMLElement) {
    const trigger = container.querySelector<HTMLButtonElement>(".select-trigger")!;
    const dropdown = container.querySelector<HTMLUListElement>(".select-dropdown")!;
    const label = container.querySelector<HTMLSpanElement>(".select-label")!;
    const hiddenInput = container.querySelector<HTMLInputElement>("#productValue")!;
    const options = container.querySelectorAll<HTMLLIElement>(".select-option");

    function open() {
      dropdown.classList.add("open");
      trigger.setAttribute("aria-expanded", "true");
    }

    function close() {
      dropdown.classList.remove("open");
      trigger.setAttribute("aria-expanded", "false");
    }

    trigger.addEventListener("click", () => {
      const isOpen = dropdown.classList.contains("open");
      isOpen ? close() : open();
    });

    options.forEach((option) => {
      option.addEventListener("click", () => {
        const value = option.dataset.value ?? "";
        hiddenInput.value = value;
        label.textContent = value;
        label.classList.add("selected");
        options.forEach((o) => o.classList.remove("active"));
        option.classList.add("active");
        close();
      });
    });

    document.addEventListener("click", (e) => {
      if (!container.contains(e.target as Node)) close();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") close();
    });
  }

  const selectEl = document.getElementById("productSelect") as HTMLElement | null;
  if (selectEl) initCustomSelect(selectEl);
</script>
